{{> menu}}

<style>
 
</style>

<div class="ui container about-container">
  
  <h1 class="ui header">
    <i class="info circle icon"></i>
    <div class="content">
      About Us
      <div class="sub header">Meet the creator and learn more about our app</div>
    </div>
  </h1>

  {{#each creators}}
  <div class="creator-card">
    <div class="ui grid">
      <div class="four wide column center aligned">
        <i class="circular huge user icon"></i>
      </div>
      <div class="twelve wide column">
        <h2 >{{this.name}}</h2>
        <p >{{this.role}}</p>
        <p><i class="map marker icon"></i> {{this.location}}</p>
      </div>
    </div>
  </div>
  {{/each}}

  <div class="ui two column stackable grid" >
    <div class="eight wide column">
      <h3 class="ui header">
        <i class="map icon" ></i>
        Our Location
      </h3>
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d4480.148313363105!2d-7.137501830792906!3d52.246685912532975!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4842c41310dd4131%3A0x4042f0dcf13f7cfe!2sSouth%20East%20Technological%20University%20%7C%20Waterford%20(SETU)!5e0!3m2!1sen!2sie!4v1773154169466!5m2!1sen!2sie" width="580" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      <p><i class="map pin icon"></i> Based in Waterford, Ireland</p>
    </div>
    
    <div class="eight wide column">
      <h3 class="ui header">
        <i class="phone icon" ></i>
        Contact Information
      </h3>
      <div class="contact-info">
  <div class="contact-item">
    <i class="envelope icon"></i>
    <span>{{creators.[0].email}}</span>
  </div>
  <div class="contact-item">
    <i class="phone icon"></i>
    <span>{{creators.[0].phone}}</span>
  </div>
  <div class="contact-item">
    <i class="map marker icon"></i>
    <span>{{creators.[0].location}}</span>
  </div>
  <div class="contact-item">
    <i class="github icon"></i>
    <span>github.com/kartier3</span>
  </div>
</div>
    </div>
  </div>

  
<div>
    <p>ㅤ</p>
  </div>
    <footer>
    <p>
      This web application was developed as part of the Web App Design CA1 assignment.
      Built with Node.js, Express, Handlebars, and Semantic UI following MVC architecture.
    </p>
  </div>
  
</footer>
</div>